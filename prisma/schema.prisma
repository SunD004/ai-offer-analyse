generator client {
  provider        = "prisma-client"
  output          = "../lib/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  parent    Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[] @relation("FolderTree")
  documents Document[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  ERROR
}

model Document {
  id              String         @id @default(cuid())
  filename        String
  originalName    String
  mimeType        String
  size            Int
  status          DocumentStatus @default(PENDING)
  errorMessage    String?
  ocrText         String?
  folderId        String?
  folder          Folder?        @relation(fields: [folderId], references: [id], onDelete: SetNull)
  chunks          DocumentChunk[]
  chatbots        ChatbotDocument[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    String
  chunkIndex Int
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([documentId])
}

model Chatbot {
  id            String            @id @default(cuid())
  name          String
  description   String?
  systemPrompt  String            @default("You are a helpful assistant. Answer questions based on the provided document context.")
  marketConfig  Json?
  documents     ChatbotDocument[]
  conversations Conversation[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model ChatbotDocument {
  chatbotId  String
  chatbot    Chatbot  @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([chatbotId, documentId])
}

model Conversation {
  id        String    @id @default(cuid())
  title     String?
  chatbotId String
  chatbot   Chatbot   @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum MessageRole {
  USER
  ASSISTANT
}

model Message {
  id             String       @id @default(cuid())
  role           MessageRole
  content        String
  sources        Json?
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}
